{
  "bar": {
    "centerAnchor": "omarchy.clock",
    "layout": {
      "center": [
        {
          "format": "dddd HH:mm",
          "formatAlt": "d MMMM 'W'ww yyyy",
          "id": "omarchy.clock",
          "verticalFormat": "HH\n—\nmm"
        },
        {
          "id": "omarchy.weather"
        },
        {
          "id": "omarchy.system-update"
        },
        {
          "id": "omarchy.indicators"
        }
      ],
      "left": [
        {
          "id": "omarchy.menu"
        },
        {
          "id": "omarchy.workspaces"
        }
      ],
      "right": [
        {
          "id": "btc",
          "type": "command",
          "exec": "~/.config/omarchy/bar/scripts/btc-ticker",
          "interval": 60,
          "tooltip": "Bitcoin price",
          "onClick": "xdg-open https://www.coingecko.com/en/coins/bitcoin"
        },
        {
          "id": "omarchy.model-usage",
          "providers": {
            "claude": {
              "enabled": true,
              "statsPath": "~/.claude/stats-cache.json",
              "credentialsPath": "~/.claude/.credentials.json",
              "projectsPath": "~/.claude/projects"
            },
            "codex": {
              "enabled": false
            }
          },
          "refreshIntervalSec": 900,
          "syncMode": "Off",
          "syncDir": "",
          "syncFileName": "",
          "syncDeviceId": ""
        },
        {
          "id": "omarchy.tray"
        },
        {
          "id": "vpn",
          "type": "command",
          "exec": "~/.config/omarchy/bar/scripts/vpn-status",
          "interval": 5,
          "tooltip": "VPN",
          "onClick": "openaws-vpn-client"
        },
        {
          "id": "omarchy.tailscale"
        },
        {
          "id": "omarchy.bluetooth"
        },
        {
          "id": "omarchy.network"
        },
        {
          "id": "omarchy.audio"
        },
        {
          "id": "omarchy.monitor"
        },
        {
          "id": "omarchy.power"
        }
      ]
    },
    "position": "top",
    "transparent": false
  },
  "idle": {
    "lock": 300,
    "screensaver": 150
  },
  "plugins": [],
  "version": 1
}
